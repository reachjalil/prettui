{
  "name": "@prettui/cli",
  "version": "0.1.1",
  "description": "Command-line demo runner for prettui terminal UI packages.",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "homepage": "https://github.com/reachjalil/prettui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reachjalil/prettui.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/reachjalil/prettui/issues"
  },
  "keywords": [
    "prettui",
    "terminal",
    "tui",
    "cli",
    "demo",
    "typescript"
  ],
  "bin": {
    "prettui": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "pnpm run clean && node ../../scripts/build-package.mjs && tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "pack:dry-run": "pnpm pack --dry-run",
    "prepack": "pnpm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "dependencies": {
    "@prettui/demo": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "esbuild": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
