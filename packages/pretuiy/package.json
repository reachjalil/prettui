{
  "name": "pretuiy",
  "version": "0.1.0",
  "description": "Composable terminal UI rendering primitives, panels, charts, dashboard layouts, and a kitchen-sink demo CLI.",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "homepage": "https://github.com/reachjalil/pretuiy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reachjalil/pretuiy.git",
    "directory": "packages/pretuiy"
  },
  "bugs": {
    "url": "https://github.com/reachjalil/pretuiy/issues"
  },
  "keywords": [
    "pretuiy",
    "terminal",
    "tui",
    "ansi",
    "charts",
    "dashboard",
    "cli",
    "typescript"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pretuiy": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "pnpm run clean && node scripts/build.mjs && tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "pack:dry-run": "pnpm pack --dry-run",
    "prepack": "pnpm run build",
    "test": "vitest run"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ansi": {
      "types": "./dist/ansi.d.ts",
      "import": "./dist/ansi.js"
    },
    "./charts": {
      "types": "./dist/charts.d.ts",
      "import": "./dist/charts.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./demo": {
      "types": "./dist/demo/index.d.ts",
      "import": "./dist/demo/index.js"
    },
    "./framework": {
      "types": "./dist/framework/index.d.ts",
      "import": "./dist/framework/index.js"
    },
    "./layout": {
      "types": "./dist/layout.d.ts",
      "import": "./dist/layout.js"
    },
    "./layouts": {
      "types": "./dist/layouts/index.d.ts",
      "import": "./dist/layouts/index.js"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "esbuild": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
