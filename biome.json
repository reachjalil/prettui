{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "root": true,
  "files": {
    "includes": ["**", "!**/node_modules", "!**/dist", "!**/build", "!**/.turbo", "!**/coverage"]
  },
  "formatter": {
    "enabled": true,
    "includes": ["*.{js,jsx,ts,tsx,mts,cts,cjs,mjs,json,jsonc,md,mdx,css}", "**/*.{js,jsx,ts,tsx,mts,cts,cjs,mjs,json,jsonc,md,mdx,css}"],
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 140,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "trailingCommas": "es5",
      "semicolons": "always"
    }
  },
  "linter": {
    "enabled": true,
    "includes": ["*.{js,jsx,ts,tsx,mts,cts,cjs,mjs,json,jsonc,css}", "**/*.{js,jsx,ts,tsx,mts,cts,cjs,mjs,json,jsonc,css}"],
    "domains": {
      "project": "none",
      "test": "none"
    },
    "rules": {
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "off"
      },
      "style": {
        "useConst": "error",
        "useTemplate": "warn",
        "noNonNullAssertion": "off",
        "useNamingConvention": "off",
        "useFilenamingConvention": "off"
      },
      "suspicious": {
        "noControlCharactersInRegex": "off",
        "noExplicitAny": "off"
      }
    }
  },
  "assist": {
    "enabled": false
  }
}
