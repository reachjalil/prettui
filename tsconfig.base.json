{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "pretuiy": ["packages/pretuiy/src/index.ts"],
      "pretuiy/ansi": ["packages/pretuiy/src/ansi.ts"],
      "pretuiy/charts": ["packages/pretuiy/src/charts.ts"],
      "pretuiy/components": ["packages/pretuiy/src/components/index.ts"],
      "pretuiy/demo": ["packages/pretuiy/src/demo/index.ts"],
      "pretuiy/layout": ["packages/pretuiy/src/layout.ts"],
      "pretuiy/layouts": ["packages/pretuiy/src/layouts/index.ts"]
    }
  }
}
