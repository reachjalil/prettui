{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@prettui/core": ["packages/core/src/index.ts"],
      "@prettui/core/ansi": ["packages/core/src/ansi.ts"],
      "@prettui/core/charts": ["packages/core/src/charts.ts"],
      "@prettui/core/layout": ["packages/core/src/layout.ts"],
      "@prettui/components": ["packages/components/src/index.ts"],
      "@prettui/dashboard": ["packages/dashboard/src/index.ts"],
      "@prettui/demo": ["packages/demo/src/index.ts"],
      "@prettui/framework": ["packages/framework/src/index.ts"],
      "@prettui/kit": ["packages/kit/src/index.ts"],
      "@prettui/layouts": ["packages/layouts/src/index.ts"]
    }
  }
}
